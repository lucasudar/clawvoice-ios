// Secrets.swift — copy this file to Secrets.swift and fill in your values.
// Secrets.swift is gitignored and never committed.
//
// You can also leave everything empty ("") and configure in-app via Settings ⚙️

struct Secrets {
    // Gemini API key — get one free at https://aistudio.google.com/apikey
    static let geminiApiKey = ""

    // OpenClaw gateway URL (no trailing slash)
    // Examples:
    //   "https://my-machine.tail06d585.ts.net"  (Tailscale HTTPS)
    //   "http://192.168.1.100"                   (local network)
    static let openClawHost = ""

    // OpenClaw gateway port (443 for HTTPS, 18789 for default HTTP)
    static let openClawPort = 443

    // Gateway token from your openclaw.json
    static let openClawToken = ""
}
